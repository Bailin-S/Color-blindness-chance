#include <iostream>
using namespace std;

void input (int& father, int& mother); // This runs the input acting as another domain

void output (int& father, int& mother); // this runs the output of your in input

void repeatYorN (int& repeat); // this runs the repeat question

int main() // runs the menu and tells what is going to be displayed
{
	cout << "===============================\n";
	cout << "[ Color blindness probability ]\n";
	cout << "===============================\n";
	// title of the project
	int father; // father variable
	int mother; // mother variable
	int repeat; // repeat variable

	do {

		input(father, mother); // runs the user input choices
		output(father, mother); // runs the output depending on the input
		repeatYorN(repeat); // gives the user the option to repeat the sequence when ran
	} while (repeat == 1);
	return 0;
	// repeat statement to start over or end the sequence
}

