	while (!(cin >> father) || father > 2 || father < 1) { // limiting valid in puts
		cout << "Invalid input. Type 1 or 2: ";
		cin.clear(); // clear statement for invalid inputs
		cin.ignore(10000, '\n'); // repeat if invalid
